import { createContext, useEffect, useState, type ReactNode } from "react";
import type { PublicFeatureFlag } from "{{PROJECT_NAME}}-shared";

interface FeatureFlagContextValue {
  flags: Map<string, PublicFeatureFlag>;
  isEnabled: (key: string) => boolean;
  isLoading: boolean;
}

export const FeatureFlagContext = createContext<FeatureFlagContextValue>({
  flags: new Map(),
  isEnabled: () => false,
  isLoading: true,
});

export function FeatureFlagProvider({ children }: { children: ReactNode }) {
  const [flags, setFlags] = useState<Map<string, PublicFeatureFlag>>(new Map());
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    fetch("/api/public/flags")
      .then((res) => res.json())
      .then((data: { flags: PublicFeatureFlag[] }) => {
        const map = new Map<string, PublicFeatureFlag>();
        for (const flag of data.flags) {
          map.set(flag.key, flag);
        }
        setFlags(map);
      })
      .catch(() => {})
      .finally(() => setIsLoading(false));
  }, []);

  const isEnabled = (key: string) => flags.has(key);

  return (
    <FeatureFlagContext.Provider value={{ flags, isEnabled, isLoading }}>
      {children}
    </FeatureFlagContext.Provider>
  );
}
