import { SignJWT, jwtVerify } from "jose";
import { getEnv } from "../config/env.js";

const COOKIE_NAME = "{{PROJECT_NAME}}_session";
const MAX_AGE = 60 * 60 * 24 * 30; // 30 days

function getSecret() {
  return new TextEncoder().encode(getEnv().SESSION_SECRET!);
}

export interface SessionPayload {
  userId: string;
  provider: string;
  displayName: string;
}

export async function createSessionToken(payload: SessionPayload): Promise<string> {
  return new SignJWT({ ...payload })
    .setProtectedHeader({ alg: "HS256" })
    .setIssuedAt()
    .setExpirationTime(`${MAX_AGE}s`)
    .sign(getSecret());
}

export interface VerifiedSession {
  session: SessionPayload;
  needsRefresh: boolean;
}

export async function verifySessionToken(token: string): Promise<VerifiedSession | null> {
  try {
    const { payload } = await jwtVerify(token, getSecret());
    const iat = payload.iat ?? 0;
    const age = Math.floor(Date.now() / 1000) - iat;
    return {
      session: payload as unknown as SessionPayload,
      needsRefresh: age > MAX_AGE / 2,
    };
  } catch {
    return null;
  }
}

export function sessionCookieHeader(token: string): string {
  const env = getEnv();
  const secure = env.CLIENT_URL.startsWith("https");
  return `${COOKIE_NAME}=${token}; HttpOnly; Path=/; Max-Age=${MAX_AGE}; SameSite=Lax${secure ? "; Secure" : ""}`;
}

export function clearSessionCookieHeader(): string {
  const env = getEnv();
  const secure = env.CLIENT_URL.startsWith("https");
  return `${COOKIE_NAME}=; HttpOnly; Path=/; Max-Age=0; SameSite=Lax${secure ? "; Secure" : ""}`;
}

export function getSessionCookie(cookieHeader: string | undefined): string | null {
  if (!cookieHeader) return null;
  const match = cookieHeader.match(new RegExp(`(?:^|;\\s*)${COOKIE_NAME}=([^;]*)`));
  return match ? match[1] : null;
}

export { COOKIE_NAME };
