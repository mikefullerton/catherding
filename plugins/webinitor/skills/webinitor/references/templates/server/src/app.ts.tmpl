import { Hono } from "hono";
import { cors } from "hono/cors";
import { getEnv } from "./config/env.js";
import { errorHandler } from "./middleware/error.js";
import { requestLogger } from "./middleware/logger.js";
import healthRoutes from "./routes/health.js";
// AUTH_ROUTES_START
import { extractAuth } from "./auth/middleware.js";
import githubAuth from "./auth/github.js";
import googleAuth from "./auth/google.js";
// AUTH_ROUTES_END

export function createApp() {
  const app = new Hono();
  const env = getEnv();

  // Global middleware
  const origins = env.CORS_ORIGIN.split(",").map((o) => o.trim());
  app.use("*", cors({ origin: origins, credentials: true }));
  app.use("*", requestLogger);
  app.onError(errorHandler);

  // Public routes
  app.route("/", healthRoutes);

  // AUTH_ROUTES_START
  // OAuth provider routes (public — handle login redirects and callbacks)
  app.route("/auth", githubAuth);
  app.route("/auth", googleAuth);

  // Authenticated API routes
  const api = new Hono();
  api.use("*", extractAuth);
  // Add your authenticated routes here:
  // api.route("/some-resource", someResourceRoutes);
  app.route("/api", api);
  // AUTH_ROUTES_END

  return app;
}
