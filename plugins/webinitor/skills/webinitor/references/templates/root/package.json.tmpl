{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build:shared": "cd shared && npm install && npm run build",
    "build:server": "cd server && npm install && npm run build",
    "build:client": "cd shared && npm install && npm run build && cd ../client && npm install && npm run build",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "deploy:client": "cd client && npm run deploy",
    "migrate": "cd server && npm run migrate",
    "generate": "cd server && npm run generate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  }
}
