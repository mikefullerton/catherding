/** Health check response */
export interface HealthResponse {
  status: "ok" | "error";
  timestamp: string;
}

/** Authenticated user info returned to clients */
export interface UserInfo {
  id: string;
  provider: string;
  displayName: string;
  email?: string;
  avatarUrl?: string;
}

/** Standard API error response */
export interface ApiError {
  error: string;
  statusCode: number;
}
