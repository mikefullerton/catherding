const API_BACKEND = "{{API_BACKEND_URL}}";

interface Env {
  ASSETS: { fetch: typeof fetch };
}

export default {
  async fetch(request: Request, env: Env): Promise<Response> {
    const url = new URL(request.url);

    // Proxy /health, /api/*, and /auth/* to Railway backend
    if (url.pathname === "/health" || url.pathname.startsWith("/api/") || url.pathname.startsWith("/auth/")) {
      const backendUrl = new URL(url.pathname + url.search, API_BACKEND);
      console.log(`[proxy] ${request.method} ${url.pathname} -> ${backendUrl.toString()}`);

      const headers = new Headers(request.headers);
      headers.set("Host", new URL(API_BACKEND).host);

      const backendRes = await fetch(backendUrl.toString(), {
        method: request.method,
        headers,
        body: request.body,
        redirect: "manual",
      });

      console.log(`[proxy] response: ${backendRes.status}`);
      console.log(`[proxy] location: ${backendRes.headers.get("location") ?? "(none)"}`);

      return new Response(backendRes.body, {
        status: backendRes.status,
        headers: backendRes.headers,
      });
    }

    // Try static assets first
    const assetRes = await env.ASSETS.fetch(request);
    if (assetRes.status !== 404) {
      return assetRes;
    }

    // SPA fallback: serve index.html for unmatched routes
    const indexReq = new Request(new URL("/", request.url), request);
    return env.ASSETS.fetch(indexReq);
  },
};
