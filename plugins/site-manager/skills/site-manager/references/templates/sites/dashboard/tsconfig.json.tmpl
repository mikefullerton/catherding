{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": ".",
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*", "worker/**/*"],
  "exclude": ["node_modules", "dist"]
}
