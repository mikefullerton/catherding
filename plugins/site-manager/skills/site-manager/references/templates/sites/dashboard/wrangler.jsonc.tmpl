{
  "name": "{{PROJECT_NAME}}-dashboard",
  "main": "worker/index.ts",
  "compatibility_date": "2024-12-01",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "dashboard.{{DOMAIN}}",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "{{PROJECT_NAME}}-dashboard-db",
      "database_id": "{{D1_DATABASE_ID}}"
    }
  ],
  "triggers": {
    "crons": [
      "*/1 * * * *",
      "*/5 * * * *",
      "0 * * * *"
    ]
  },
  "vars": {
    "API_BACKEND_URL": "{{API_BACKEND_URL}}",
    "MAIN_SITE_URL": "https://{{DOMAIN}}",
    "ADMIN_SITE_URL": "https://admin.{{DOMAIN}}"
  }
}
