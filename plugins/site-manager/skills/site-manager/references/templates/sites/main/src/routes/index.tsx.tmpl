import { useAuth } from "../hooks/use-auth";

export function IndexPage() {
  const { user, isAuthenticated, isLoading } = useAuth();

  if (isLoading) {
    return (
      <div className="flex items-center justify-center min-h-[80vh]" style={{ color: "#8a8a9a" }}>
        Loading...
      </div>
    );
  }

  return (
    <div className="max-w-4xl mx-auto px-4 py-24">
      <h1 className="text-5xl font-bold mb-6" style={{ color: "#e8e6e3" }}>
        Hello, world!
      </h1>
      <p className="text-xl mb-2" style={{ color: "#8a8a9a" }}>
        Welcome to <span style={{ color: "#c4a35a" }}>{{DISPLAY_NAME}}</span>.
      </p>
      <p className="text-lg mb-10" style={{ color: "#5a5a6a" }}>
        This is the main public-facing site, served by a Cloudflare Worker with a React SPA frontend
        and a Hono API backend on Railway.
      </p>

      {isAuthenticated ? (
        <div
          className="p-6 rounded-lg"
          style={{ background: "#14141a", border: "1px solid #2a2a36" }}
        >
          <p style={{ color: "#5cb270" }}>Signed in as {user?.displayName ?? user?.email}</p>
        </div>
      ) : (
        <div className="flex gap-4">
          <a
            href="/register"
            className="px-6 py-3 rounded-lg font-medium transition hover:opacity-90"
            style={{ background: "#c4a35a", color: "#0c0c0f" }}
          >
            Create Account
          </a>
          <a
            href="/login"
            className="px-6 py-3 rounded-lg transition hover:opacity-80"
            style={{ border: "1px solid #2a2a36", color: "#e8e6e3" }}
          >
            Log In
          </a>
        </div>
      )}
    </div>
  );
}
