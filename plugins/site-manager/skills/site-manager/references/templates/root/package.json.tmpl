{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "backend",
    "sites/main",
    "sites/admin",
    "sites/dashboard"
  ],
  "scripts": {
    "dev": "concurrently -n backend,main,admin,dashboard -c blue,green,yellow,magenta \"npm run dev -w backend\" \"npm run dev -w sites/main\" \"npm run dev -w sites/admin\" \"npm run dev -w sites/dashboard\"",
    "build:shared": "npm run build -w shared",
    "build:backend": "npm run build -w backend",
    "build:main": "npm run build -w sites/main",
    "build:admin": "npm run build -w sites/admin",
    "build:dashboard": "npm run build -w sites/dashboard",
    "build:all": "npm run build:shared && npm run build:backend && npm run build:main && npm run build:admin && npm run build:dashboard",
    "deploy:main": "npm run deploy -w sites/main",
    "deploy:admin": "npm run deploy -w sites/admin",
    "deploy:dashboard": "npm run deploy -w sites/dashboard",
    "deploy:all": "npm run deploy:main && npm run deploy:admin && npm run deploy:dashboard",
    "db:generate": "npm run db:generate -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
