{
  "deny": [
    {
      "matcher": "ExitPlanMode",
      "pattern": "",
      "reason": "User should review the plan before execution"
    },
    {
      "matcher": "Bash",
      "pattern": "git push --force",
      "reason": "Force push is destructive and can overwrite remote history"
    },
    {
      "matcher": "Bash",
      "pattern": "git push.*--force",
      "reason": "Force push is destructive and can overwrite remote history"
    },
    {
      "matcher": "Bash",
      "pattern": "git reset --hard",
      "reason": "Hard reset discards uncommitted work"
    },
    {
      "matcher": "Bash",
      "pattern": "git branch -D",
      "reason": "Deletes branch without checking if it was merged"
    },
    {
      "matcher": "Bash",
      "pattern": "rm -rf /[^.]",
      "reason": "Recursive delete outside project directory"
    },
    {
      "matcher": "Bash",
      "pattern": "rm -rf ~",
      "reason": "Recursive delete of home directory"
    }
  ]
}
