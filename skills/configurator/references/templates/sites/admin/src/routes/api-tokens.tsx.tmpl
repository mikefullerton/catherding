import { useState } from "react";
import { useApiTokens, useCreateApiToken, useDeleteApiToken } from "../api/admin";

const AVAILABLE_CAPABILITIES = [
  { value: "api:read", label: "API Read" },
  { value: "api:write", label: "API Write" },
  { value: "messaging:send", label: "Send Messages" },
  { value: "users:read", label: "Read Users" },
  { value: "users:write", label: "Write Users" },
];

export function ApiTokensPage() {
  const { data, isLoading } = useApiTokens();
  const createToken = useCreateApiToken();
  const deleteToken = useDeleteApiToken();

  const [newName, setNewName] = useState("");
  const [selectedCaps, setSelectedCaps] = useState<string[]>([]);
  const [revealedSecret, setRevealedSecret] = useState<{ name: string; keyId: string; secret: string } | null>(null);
  const [copied, setCopied] = useState(false);

  async function handleCreate() {
    if (!newName) return;
    const result = await createToken.mutateAsync({ name: newName, capabilities: selectedCaps });
    setRevealedSecret({ name: result.name, keyId: result.keyId, secret: result.secret });
    setNewName("");
    setSelectedCaps([]);
    setCopied(false);
  }

  function toggleCapability(cap: string) {
    setSelectedCaps((prev) =>
      prev.includes(cap) ? prev.filter((c) => c !== cap) : [...prev, cap],
    );
  }

  function handleCopy() {
    if (revealedSecret) {
      navigator.clipboard.writeText(revealedSecret.secret);
      setCopied(true);
    }
  }

  function handleDismissSecret() {
    setRevealedSecret(null);
    setCopied(false);
  }

  return (
    <div>
      <h1 className="text-2xl font-bold mb-6">API Tokens</h1>

      {/* Secret reveal modal */}
      {revealedSecret && (
        <div className="mb-6 p-4 border-2 border-yellow-400 bg-yellow-50 rounded-lg">
          <p className="font-bold text-yellow-800 mb-2">
            Save your API secret — it will not be shown again
          </p>
          <p className="text-sm text-gray-600 mb-1">
            Token: <span className="font-medium">{revealedSecret.name}</span>
          </p>
          <p className="text-sm text-gray-600 mb-3">
            Key ID: <span className="font-mono">{revealedSecret.keyId}</span>
          </p>
          <div className="flex items-center gap-2 mb-3">
            <code className="flex-1 p-2 bg-white border rounded font-mono text-sm break-all">
              {revealedSecret.secret}
            </code>
            <button
              onClick={handleCopy}
              className="px-3 py-2 bg-gray-800 text-white rounded text-sm hover:bg-gray-700 whitespace-nowrap"
            >
              {copied ? "Copied" : "Copy"}
            </button>
          </div>
          <button
            onClick={handleDismissSecret}
            className="text-sm text-gray-600 hover:text-gray-800 underline"
          >
            I've saved the secret — dismiss
          </button>
        </div>
      )}

      {/* Create new token */}
      <div className="mb-6 p-4 border rounded-lg bg-gray-50">
        <div className="flex gap-2 mb-3">
          <input
            type="text"
            placeholder="Token name (e.g. CI/CD, mobile-app)"
            value={newName}
            onChange={(e) => setNewName(e.target.value)}
            onKeyDown={(e) => { if (e.key === "Enter") handleCreate(); }}
            className="px-3 py-2 border rounded-lg flex-1"
          />
          <button
            onClick={handleCreate}
            disabled={createToken.isPending || !newName}
            className="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50"
          >
            Create Token
          </button>
        </div>
        <div>
          <p className="text-sm font-medium text-gray-700 mb-2">Capabilities</p>
          <div className="flex flex-wrap gap-2">
            {AVAILABLE_CAPABILITIES.map((cap) => (
              <label key={cap.value} className="flex items-center gap-1.5 text-sm cursor-pointer">
                <input
                  type="checkbox"
                  checked={selectedCaps.includes(cap.value)}
                  onChange={() => toggleCapability(cap.value)}
                  className="rounded"
                />
                {cap.label}
              </label>
            ))}
          </div>
        </div>
      </div>

      {/* Token list */}
      {isLoading ? (
        <p>Loading...</p>
      ) : data?.tokens.length === 0 ? (
        <p className="text-gray-500">No API tokens yet. Create one above.</p>
      ) : (
        <table className="w-full border-collapse">
          <thead>
            <tr className="border-b text-left">
              <th className="py-2 px-3">Name</th>
              <th className="py-2 px-3">Key ID</th>
              <th className="py-2 px-3">Capabilities</th>
              <th className="py-2 px-3">Created</th>
              <th className="py-2 px-3">Last Used</th>
              <th className="py-2 px-3">Actions</th>
            </tr>
          </thead>
          <tbody>
            {data?.tokens.map((token) => (
              <tr key={token.id} className="border-b hover:bg-gray-50">
                <td className="py-2 px-3 text-sm font-medium">{token.name}</td>
                <td className="py-2 px-3 font-mono text-sm text-gray-500">{token.keyId}</td>
                <td className="py-2 px-3 text-sm text-gray-500">
                  {token.capabilities?.length
                    ? token.capabilities.join(", ")
                    : <span className="italic">none</span>}
                </td>
                <td className="py-2 px-3 text-sm text-gray-500">
                  {new Date(token.createdAt).toLocaleDateString()}
                </td>
                <td className="py-2 px-3 text-sm text-gray-500">
                  {token.lastUsedAt ? new Date(token.lastUsedAt).toLocaleDateString() : "Never"}
                </td>
                <td className="py-2 px-3">
                  <button
                    onClick={() => {
                      if (confirm(`Revoke token "${token.name}"? API calls using this token will stop working.`)) {
                        deleteToken.mutate(token.id);
                      }
                    }}
                    className="text-red-600 text-sm hover:underline"
                  >
                    Revoke
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  );
}
