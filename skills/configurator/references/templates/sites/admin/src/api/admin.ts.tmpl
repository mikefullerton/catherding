// ── API Tokens ──────────────────────────────────────────────────────────

interface ApiToken {
  id: string;
  name: string;
  keyId: string;
  capabilities: string[];
  createdBy: string;
  lastUsedAt: string | null;
  expiresAt: string | null;
  createdAt: string;
}

interface CreatedApiToken extends ApiToken {
  secret: string;
}

export function useApiTokens() {
  const apiFetch = useApiFetch();
  return useQuery({
    queryKey: ["admin", "api-tokens"],
    queryFn: async () => {
      const res = await apiFetch("/api/admin/api-tokens");
      if (!res.ok) throw new Error("Failed to fetch API tokens");
      return res.json() as Promise<{ tokens: ApiToken[] }>;
    },
  });
}

export function useCreateApiToken() {
  const apiFetch = useApiFetch();
  const qc = useQueryClient();
  return useMutation({
    mutationFn: async (data: { name: string; capabilities?: string[] }) => {
      const res = await apiFetch("/api/admin/api-tokens", {
        method: "POST",
