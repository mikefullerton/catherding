import { useState, type FormEvent } from "react";
import { useAuth } from "../hooks/use-auth";

export function LoginPage() {
  const { login } = useAuth();
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [error, setError] = useState<string | null>(null);
  const [isSubmitting, setIsSubmitting] = useState(false);

  async function handleSubmit(e: FormEvent) {
    e.preventDefault();
    setError(null);
    setIsSubmitting(true);

    try {
      await login(email, password);
      window.location.href = "/";
    } catch (err) {
      setError(err instanceof Error ? err.message : "Login failed");
    } finally {
      setIsSubmitting(false);
    }
  }

  return (
    <div className="min-h-screen flex items-center justify-center" style={{ background: "#0c0c0f" }}>
      <div
        className="w-full max-w-sm p-6 rounded-lg"
        style={{ background: "#14141a", border: "1px solid #2a2a36" }}
      >
        <h1 className="text-xl font-bold mb-1" style={{ color: "#c4a35a" }}>
          {{DISPLAY_NAME}}
        </h1>
        <p className="text-sm mb-6" style={{ color: "#5a5a6a" }}>Log in to your account</p>
        <form onSubmit={handleSubmit} className="space-y-4">
          {error && (
            <div
              className="p-3 text-sm rounded-lg"
              style={{ background: "rgba(212, 84, 84, 0.1)", border: "1px solid rgba(212, 84, 84, 0.3)", color: "#d45454" }}
            >
              {error}
            </div>
          )}
          <div>
            <label htmlFor="email" className="block text-sm font-medium mb-1" style={{ color: "#8a8a9a" }}>
              Email
            </label>
            <input
              id="email"
              type="email"
              value={email}
              onChange={(e) => setEmail(e.target.value)}
              required
              className="w-full px-3 py-2 rounded-lg outline-none"
              style={{ background: "#1c1c24", border: "1px solid #2a2a36", color: "#e8e6e3" }}
            />
          </div>
          <div>
            <label htmlFor="password" className="block text-sm font-medium mb-1" style={{ color: "#8a8a9a" }}>
              Password
            </label>
            <input
              id="password"
              type="password"
              value={password}
              onChange={(e) => setPassword(e.target.value)}
              required
              className="w-full px-3 py-2 rounded-lg outline-none"
              style={{ background: "#1c1c24", border: "1px solid #2a2a36", color: "#e8e6e3" }}
            />
          </div>
          <button
            type="submit"
            disabled={isSubmitting}
            className="w-full py-2 rounded-lg transition hover:opacity-90 disabled:opacity-50 font-medium"
            style={{ background: "#c4a35a", color: "#0c0c0f" }}
          >
            {isSubmitting ? "Logging in..." : "Log In"}
          </button>
          <p className="text-sm text-center" style={{ color: "#5a5a6a" }}>
            Don't have an account?{" "}
            <a href="/register" style={{ color: "#c4a35a" }} className="hover:opacity-80">
              Register
            </a>
          </p>
        </form>
      </div>
    </div>
  );
}
