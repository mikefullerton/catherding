import type { ProblemDetails } from "./types.js";

export class ApiError extends Error {
  constructor(
    public status: number,
    public problem: ProblemDetails,
  ) {
    super(problem.title);
    this.name = "ApiError";
  }
}

interface ApiClientConfig {
  baseUrl: string;
  getAccessToken: () => string | null;
  setAccessToken: (token: string | null) => void;
}

const MAX_RETRIES = 3;
const CIRCUIT_BREAKER_THRESHOLD = 5;
const CIRCUIT_BREAKER_RESET_MS = 30_000;

function jitteredDelay(attempt: number): number {
  const base = Math.min(1000 * 2 ** attempt, 10_000);
  return base + Math.random() * base * 0.1;
}

class CircuitBreaker {
  private failures = 0;
  private lastFailure = 0;
  private state: "closed" | "open" | "half-open" = "closed";

  canRequest(): boolean {
    if (this.state === "closed") return true;
    if (this.state === "open") {
      if (Date.now() - this.lastFailure > CIRCUIT_BREAKER_RESET_MS) {
        this.state = "half-open";
        return true;
      }
      return false;
    }
    return true; // half-open: allow one request
  }

  recordSuccess(): void {
    this.failures = 0;
    this.state = "closed";
  }

  recordFailure(): void {
    this.failures++;
    this.lastFailure = Date.now();
    if (this.failures >= CIRCUIT_BREAKER_THRESHOLD) {
      this.state = "open";
    }
  }
}

function createApiClient(config: ApiClientConfig) {
  const breaker = new CircuitBreaker();

  async function request<T>(
    path: string,
    options: RequestInit = {},
    retryCount = 0,
  ): Promise<T> {
    if (!breaker.canRequest()) {
      throw new ApiError(503, {
        type: "about:blank",
        title: "Service unavailable",
        status: 503,
        detail: "Circuit breaker is open",
      });
    }

    const headers = new Headers(options.headers);
    if (!headers.has("Content-Type") && options.body) {
      headers.set("Content-Type", "application/json");
    }
    const accessToken = config.getAccessToken();
    if (accessToken) {
      headers.set("Authorization", `Bearer ${accessToken}`);
    }

    try {
      const res = await fetch(`${config.baseUrl}${path}`, {
        ...options,
        headers,
        credentials: "include",
      });

      if (res.status === 401 && accessToken) {
        const refreshed = await refreshAccessToken(config);
        if (refreshed) {
          return request<T>(path, options, retryCount);
        }
        config.setAccessToken(null);
        throw new ApiError(401, { type: "about:blank", title: "Session expired", status: 401 });
      }

      if (!res.ok) {
        const problem = (await res.json().catch(() => ({
          type: "about:blank",
          title: res.statusText,
          status: res.status,
        }))) as ProblemDetails;
        throw new ApiError(res.status, problem);
      }

      breaker.recordSuccess();
      return (await res.json()) as T;
    } catch (err) {
      if (err instanceof ApiError) {
        if (err.status >= 500 && retryCount < MAX_RETRIES) {
          breaker.recordFailure();
          await new Promise((r) => setTimeout(r, jitteredDelay(retryCount)));
          return request<T>(path, options, retryCount + 1);
        }
        throw err;
      }
      // Network error
      breaker.recordFailure();
      if (retryCount < MAX_RETRIES) {
        await new Promise((r) => setTimeout(r, jitteredDelay(retryCount)));
        return request<T>(path, options, retryCount + 1);
      }
      throw new ApiError(0, {
        type: "about:blank",
        title: "Network error",
        status: 0,
        detail: err instanceof Error ? err.message : "Unknown error",
      });
    }
  }

  return {
    get: <T>(path: string) => request<T>(path),
    post: <T>(path: string, body: unknown) =>
      request<T>(path, { method: "POST", body: JSON.stringify(body) }),
    patch: <T>(path: string, body: unknown) =>
      request<T>(path, { method: "PATCH", body: JSON.stringify(body) }),
    delete: <T>(path: string) => request<T>(path, { method: "DELETE" }),
  };
}

async function refreshAccessToken(config: ApiClientConfig): Promise<boolean> {
  try {
    const accessToken = config.getAccessToken();
    const res = await fetch(`${config.baseUrl}/api/auth/refresh`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        ...(accessToken ? { Authorization: `Bearer ${accessToken}` } : {}),
      },
      credentials: "include", // sends httpOnly refresh_token cookie
    });

    if (!res.ok) return false;

    const data = (await res.json()) as { accessToken: string };
    config.setAccessToken(data.accessToken);
    return true;
  } catch {
    return false;
  }
}

export { createApiClient };
export type { ApiClientConfig };
