{{#IF_GITHUB_OAUTH}}
import { Hono } from "hono";
import { db } from "../db/client.js";
import { users, userAuthMethods } from "../db/schema.js";
import { eq, and } from "drizzle-orm";
import { createAccessToken, createRefreshToken, refreshTokenCookie } from "./session.js";
import { env } from "../config/env.js";
import type { AppEnv } from "../app.js";

export const githubAuth = new Hono<AppEnv>();

githubAuth.get("/", (c) => {
  const params = new URLSearchParams({
    client_id: env.GITHUB_CLIENT_ID!,
    scope: "read:user user:email",
  });
  return c.redirect(`https://github.com/login/oauth/authorize?${params}`);
});

githubAuth.get("/callback", async (c) => {
  const code = c.req.query("code");
  if (!code) {
    return c.json({ type: "about:blank", title: "Missing code parameter", status: 400 }, 400);
  }

  // Exchange code for access token
  const tokenRes = await fetch("https://github.com/login/oauth/access_token", {
    method: "POST",
    headers: { "Content-Type": "application/json", Accept: "application/json" },
    body: JSON.stringify({
      client_id: env.GITHUB_CLIENT_ID,
      client_secret: env.GITHUB_CLIENT_SECRET,
      code,
    }),
  });
  const tokenData = (await tokenRes.json()) as { access_token?: string; error?: string };

  if (!tokenData.access_token) {
    return c.json({ type: "about:blank", title: "GitHub OAuth failed", status: 400 }, 400);
  }

  // Fetch GitHub user
  const userRes = await fetch("https://api.github.com/user", {
    headers: { Authorization: `Bearer ${tokenData.access_token}` },
  });
  const ghUser = (await userRes.json()) as { id: number; login: string; email: string; avatar_url: string };

  // Fetch email if not public
  let email = ghUser.email;
  if (!email) {
    const emailRes = await fetch("https://api.github.com/user/emails", {
      headers: { Authorization: `Bearer ${tokenData.access_token}` },
    });
    const emails = (await emailRes.json()) as Array<{ email: string; primary: boolean; verified: boolean }>;
    const primary = emails.find((e) => e.primary && e.verified);
    email = primary?.email ?? emails[0]?.email ?? "";
  }

  const providerId = String(ghUser.id);

  // Check for existing auth method
  const [existingAuth] = await db
    .select()
    .from(userAuthMethods)
    .where(and(eq(userAuthMethods.provider, "github"), eq(userAuthMethods.providerId, providerId)));

  let userId: string;

  if (existingAuth) {
    userId = existingAuth.userId;
  } else {
    // Check if user exists by email
    const [existingUser] = await db.select().from(users).where(eq(users.email, email));

    if (existingUser) {
      userId = existingUser.id;
    } else {
      const [newUser] = await db
        .insert(users)
        .values({
          email,
          displayName: ghUser.login,
          avatarUrl: ghUser.avatar_url,
          emailVerified: true,
        })
        .returning();
      if (!newUser) throw new Error("Failed to create user");
      userId = newUser.id;
    }

    await db.insert(userAuthMethods).values({
      userId,
      provider: "github",
      providerId,
    });
  }

  const [user] = await db.select().from(users).where(eq(users.id, userId));
  if (!user) throw new Error("User not found after OAuth link");
  const accessToken = await createAccessToken({ sub: user.id, email: user.email, role: user.role });
  const refresh = await createRefreshToken(user.id, true);

  c.header("Set-Cookie", refreshTokenCookie(refresh.raw, refresh.expiresAt));
  return c.redirect(
    `${env.CLIENT_URL}/auth/callback?access_token=${accessToken}`,
  );
});
{{/IF_GITHUB_OAUTH}}
